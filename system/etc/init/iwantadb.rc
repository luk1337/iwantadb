on init
    exec u:r:su:s0 root root -- /system/bin/iwantadb
    exec u:r:sysinit:s0 root root -- /system/bin/iwantadb

on property:init.svc.zygote=running
    exec_background u:r:su:s0 root root -- /system/bin/iwantadb disable_trust
    exec_background u:r:sysinit:s0 root root -- /system/bin/iwantadb disable_trust
